# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# Data & artifacts (never commit participant data)
data/
*.snirf
*.xdf
*.nwb
bids/

# Unity
unity/Library/
unity/Temp/
unity/Obj/
unity/Logs/
unity/UserSettings/
*.csproj
*.sln

# Stray Unity project regenerated at the MONOREPO ROOT (the real project is in
# unity/). A misdirected Unity Editor sometimes recreates an empty shell here;
# these root-anchored ignores keep that junk out of git. They do NOT affect
# unity/Assets, unity/Packages, etc. (those are not at the repo root).
/Assets/
/Packages/
/ProjectSettings/
/Library/
/Logs/
/Temp/
/obj/
/UserSettings/

# IDE
.vs/
.idea/
.vscode/

# Claude Code (machine-local settings & permissions)
.claude/settings.local.json

# Env / secrets
.env
*.local.yaml
